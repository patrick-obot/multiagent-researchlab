<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pilab.api</string>
    <key>WorkingDirectory</key>
    <string>/Users/macmini/Projects/pilab</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PILAB_DB_PATH</key>
        <string>/Users/macmini/Projects/pilab/data/pilab.db</string>
        <key>PATH</key>
        <string>/Users/macmini/Projects/pilab/.venv/bin:/usr/local/bin:/usr/bin:/bin</string>
