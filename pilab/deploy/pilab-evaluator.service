[Unit]
Description=PiLab Evaluator Agent
After=network.target pilab-api.service

[Service]
Type=simple
User=mypi
WorkingDirectory=/home/mypi/Projects/multiagent_researchlab
Environment=PILAB_API_BASE_URL=http://192.168.1.35:8000
Environment=PILAB_LLM_EVALUATOR_URL=http://localhost:8081
ExecStart=/home/mypi/Projects/multiagent_researchlab/.venv/bin/python -m pilab.evaluator.agent
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
